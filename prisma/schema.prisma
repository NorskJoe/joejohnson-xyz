// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
}

datasource db {
  provider = "mongodb"
}

model Recipe {
  id                String       @id @default(auto()) @map("_id") @db.ObjectId
  title             String
  description       String?
  servings          Int?
  prepTimeInMinutes Int?
  cookTimeInMinutes Int?
  steps             String[]     @default([])
  tags              String[]     @default([])
  ingredients       Ingredient[]
}

model Ingredient {
  id            String                 @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  amount        Float?
  measurement   IngredientMeasurement? @relation(fields: [measurementId], references: [id])
  measurementId String?                @db.ObjectId
  recipe        Recipe                 @relation(fields: [recipeId], references: [id])
  recipeId      String                 @db.ObjectId
  notes         String?
  position      Int? // ordering within the recipe
}

model IngredientMeasurement {
  id           String          @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  abbreviation String?
  type         MeasurementType @default(OTHER)
  notes        String?
  createdAt    DateTime        @default(now())
  ingredients  Ingredient[]
}

enum MeasurementType {
  GRAMS
  KGS
  TBSP
  TSP
  CUP
  ML
  LITRE
  OTHER
}
