// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "generated/client"
}

datasource db {
  provider = "postgresql"
}

model Recipe {
  id                Int                @id @default(autoincrement())
  title             String
  slug              String             @unique
  description       String?
  servings          Int?
  prepTimeInMinutes Int?
  cookTimeInMinutes Int?
  instructions      String[]           @default([])
  tags              String[]           @default([])
  recipeIngredients RecipeIngredient[]
}

model Ingredient {
  id                Int                @id @default(autoincrement())
  name              String
  recipeIngredients RecipeIngredient[]
}

model IngredientMeasurement {
  id                Int                @id @default(autoincrement())
  type              MeasurementType    @unique @default(OTHER)
  recipeIngredients RecipeIngredient[]
}

model RecipeIngredient {
  id            Int                   @id @default(autoincrement())
  recipeId      Int
  ingredientId  Int
  measurementId Int
  quantity      Float
  recipe        Recipe                @relation(fields: [recipeId], references: [id])
  ingredient    Ingredient            @relation(fields: [ingredientId], references: [id])
  measurement   IngredientMeasurement @relation(fields: [measurementId], references: [id])
}

enum MeasurementType {
  GRAMS
  KGS
  TBSP
  TSP
  CUP
  ML
  LITRE
  OTHER
}
