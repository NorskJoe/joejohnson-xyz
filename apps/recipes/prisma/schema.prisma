generator client {
  provider = "prisma-client"
  output   = "generated/client"
}

datasource db {
  provider = "postgresql"
}

model Recipe {
  id                Int                @id @default(autoincrement())
  title             String
  description       String?
  servings          Int?
  prepTimeInMinutes Int?
  cookTimeInMinutes Int?
  instructions      String[]           @default([])
  tags              String[]           @default([])
  slug              String             @unique
  recipeIngredients RecipeIngredient[]
}

model Ingredient {
  id                Int                @id @default(autoincrement())
  name              String
  recipeIngredients RecipeIngredient[]
}

model IngredientMeasurement {
  id                Int                @id @default(autoincrement())
  type              MeasurementType    @unique @default(OTHER)
  recipeIngredients RecipeIngredient[]
}

model RecipeIngredient {
  id            Int                   @id @default(autoincrement())
  recipeId      Int
  ingredientId  Int
  measurementId Int
  quantity      Float
  ingredient    Ingredient            @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  measurement   IngredientMeasurement @relation(fields: [measurementId], references: [id])
  recipe        Recipe                @relation(fields: [recipeId], references: [id], onDelete: Cascade)
}

enum MeasurementType {
  GRAM
  KG
  TBSP
  TSP
  CUP
  ML
  LITRE
  PIECE
  OTHER
}
