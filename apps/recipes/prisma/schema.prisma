// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "generated/client"
}

datasource db {
  provider = "postgresql"
}

model Recipe {
  id                Int          @id @default(autoincrement())
  title             String       @unique
  description       String?
  servings          Int?
  prepTimeInMinutes Int?
  cookTimeInMinutes Int?
  steps             String[]     @default([])
  tags              String[]     @default([])
  ingredients       Ingredient[]
}

model Ingredient {
  id            Int                    @id @default(autoincrement())
  name          String
  amount        Float?
  measurement   IngredientMeasurement? @relation(fields: [measurementId], references: [id])
  measurementId Int?
  recipe        Recipe                 @relation(fields: [recipeId], references: [id])
  recipeId      Int
  notes         String?
  position      Int? // ordering within the recipe
}

model IngredientMeasurement {
  id           Int             @id @default(autoincrement())
  name         String
  abbreviation String?
  type         MeasurementType @default(OTHER)
  notes        String?
  ingredients  Ingredient[]
}

enum MeasurementType {
  GRAMS
  KGS
  TBSP
  TSP
  CUP
  ML
  LITRE
  OTHER
}
